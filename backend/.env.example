# Runtime
NODE_ENV=development
AUTH_MODE=optional
MODEL_TIMEOUT_MS=12000

# Persistence mode
# memory: in-process only
# mirror: keep in-memory reads but mirror writes to Supabase/Redis
PERSISTENCE_MODE=mirror

# Supabase (Postgres)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Embedding configuration (must match pgvector column dimension)
EMBEDDING_DIMENSIONS=1536

# Upstash Redis (thread state + rate-limit primitives)
UPSTASH_REDIS_REST_URL=https://example-12345.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
THREAD_STATE_TTL_SECONDS=604800

# AI SDK 6
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
LOCK_CHAT_MODEL=google/gemini-2.5-flash
LOCK_FAST_MODEL=google/gemini-2.5-flash
LOCK_EMBEDDING_MODEL=google/gemini-embedding-001
LOCK_AGENT_MAX_STEPS=2

# Chat SDK
CHAT_SDK_ENABLED=false
CHAT_SDK_LOG_LEVEL=info
CHAT_BOT_USERNAME=lockedin_bot

# Optional shared Redis for Chat SDK state adapter (redis:// or rediss://)
CHAT_STATE_REDIS_URL=

# Telegram adapter
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET_TOKEN=

# Discord adapter
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_USERNAME=

# Engagement automation
# Optional shared secret for POST /v1/automation/run (send via x-automation-secret header)
AUTOMATION_SECRET=
AUTOMATION_CHECKIN_INTERVAL_DAYS=7
AUTOMATION_REMINDER_COOLDOWN_HOURS=24
AUTOMATION_STREAK_NUDGE_COOLDOWN_HOURS=24

# Local testing bootstrap profile/tasks route
# Set true only for local/dev usage.
ENABLE_TESTING_BOOTSTRAP=false
